# Copy this file to .env.local for local development
# Set these in Vercel project settings for production.

# Provider selector:
#   openrouter | openai | groq | together | fireworks | xai | custom
AI_PROVIDER=openrouter

# Optional override if you run any OpenAI-compatible gateway.
# Example: https://api.openrouter.ai/api/v1
AI_BASE_URL=

# API keys (set AI_API_KEY or provider-specific key)
AI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
XAI_API_KEY=

# Optional defaults
DEFAULT_TEXT_MODEL=google/gemini-2.5-pro
AI_INCLUDE_STREAM_USAGE=true
AI_HTTP_REFERER=http://localhost:3000
AI_APP_NAME=YAH Forge Direct

# Optional JSON map to alias current UI model labels to provider model IDs.
# MODEL_ALIASES_JSON={"Gemini-3.1-Pro":"google/gemini-2.5-pro","Claude-Sonnet-4.5":"anthropic/claude-sonnet-4"}
MODEL_ALIASES_JSON=

# Optional JSON for additional headers required by your provider.
# AI_EXTRA_HEADERS_JSON={"X-API-Version":"2024-10-01"}
AI_EXTRA_HEADERS_JSON=
